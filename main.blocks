<xml xmlns="https://developers.google.com/blockly/xml"><variables></variables><block type="pxt-on-start" id="?=3qUXWgQvA5?EP`r1w1" x="0" y="0"><statement name="HANDLER"><block type="typescript_statement" id="]d$k][gd*{lY`$5;T5IQ"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace randomMusic {" line1="    let rngSeed = 1" line2="    let currentKeyIsMajor = true" line3="    let noteLog: number[] = []" line4="    let currentWave: WaveShape = WaveShape.Sine" line5="" line6="    const majorScale = [0, 2, 4, 5, 7, 9, 11]" line7="    const minorScale = [0, 2, 3, 5, 7, 8, 10]" line8="    const instrumentWaves: WaveShape[] = [" line9="        WaveShape.Triangle," line10="        WaveShape.Sawtooth," line11="        WaveShape.Square," line12="        WaveShape.Sine," line13="        WaveShape.Noise" line14="    ]" line15="" line16="    const noteFrequencies: { [note: string]: number } = {" line17="        &quot;C4&quot;: 261.63, &quot;D4&quot;: 293.66, &quot;E4&quot;: 329.63, &quot;F4&quot;: 349.23, &quot;G4&quot;: 392.00," line18="        &quot;A4&quot;: 440.00, &quot;B4&quot;: 493.88, &quot;C5&quot;: 523.25, &quot;D5&quot;: 587.33, &quot;E5&quot;: 659.25," line19="        &quot;F5&quot;: 698.46, &quot;G5&quot;: 783.99, &quot;A5&quot;: 880.00, &quot;B5&quot;: 987.77" line20="    }" line21="" line22="    //% block=&quot;set music seed to %seed&quot;" line23="    export function setMusicSeed(seed: number): void {" line24="        rngSeed = seed" line25="    }" line26="" line27="    function seededRandom(min: number, max: number): number {" line28="        rngSeed = (rngSeed * 16807) % 2147483647" line29="        return min + (rngSeed % (max - min + 1))" line30="    }" line31="" line32="    //% block=&quot;set music key to major %isMajor&quot;" line33="    //% isMajor.shadow=&quot;toggleOnOff&quot;" line34="    export function setMusicKey(isMajor: boolean): void {" line35="        currentKeyIsMajor = isMajor" line36="    }" line37="" line38="    //% block=&quot;set instrument to %wave&quot;" line39="    //% wave.shadow=&quot;waveShapePicker&quot;" line40="    export function setInstrument(wave: WaveShape): void {" line41="        currentWave = wave" line42="    }" line43="" line44="    function randomizeInstrument() {" line45="        currentWave = instrumentWaves[seededRandom(0, instrumentWaves.length - 1)]" line46="    }" line47="" line48="    function getRandomNote(): number {" line49="        const noteKeys = Object.keys(noteFrequencies)" line50="        const selectedNote = noteKeys[seededRandom(0, noteKeys.length - 1)]" line51="        return noteFrequencies[selectedNote]" line52="    }" line53="" line54="    //% block=&quot;play random sound effect&quot;" line55="    export function playRandomSound(): void {" line56="        const freq = getRandomNote()" line57="        const duration = seededRandom(100, 400)" line58="        noteLog.push(freq)" line59="" line60="        music.play(music.createSoundEffect(" line61="            currentWave," line62="            freq," line63="            freq," line64="            255," line65="            0," line66="            duration," line67="            SoundExpressionEffect.None," line68="            InterpolationCurve.Linear" line69="        ), music.PlaybackMode.UntilDone)" line70="    }" line71="" line72="    //% block=&quot;play random rhythm sequence&quot;" line73="    export function playRandomRhythm(): void {" line74="        const beatDurations = [100, 200, 300, 400]" line75="        for (let i = 0; i &lt; 4; i++) {" line76="            playRandomSound()" line77="            pause(beatDurations[seededRandom(0, beatDurations.length - 1)])" line78="        }" line79="    }" line80="" line81="    //% block=&quot;play hybrid beat&quot;" line82="    export function playHybridBeat(): void {" line83="        const patterns: string[][] = [" line84="            [&quot;C4&quot;, &quot;-&quot;, &quot;C4&quot;, &quot;-&quot;, &quot;C4&quot;, &quot;-&quot;, &quot;C4&quot;, &quot;-&quot;]," line85="            [&quot;C4&quot;, &quot;D4&quot;, &quot;-&quot;, &quot;C4&quot;, &quot;-&quot;, &quot;E4&quot;, &quot;C4&quot;, &quot;-&quot;]," line86="            [&quot;C4&quot;, &quot;-&quot;, &quot;-&quot;, &quot;F4&quot;, &quot;G4&quot;, &quot;-&quot;, &quot;-&quot;, &quot;C4&quot;]" line87="        ]" line88="        const base = patterns[seededRandom(0, patterns.length - 1)]" line89="        const hybrid = base.map(b =&gt; {" line90="            if (b === &quot;-&quot;) {" line91="                const keys = Object.keys(noteFrequencies)" line92="                return seededRandom(0, 1) === 0 ? keys[seededRandom(0, keys.length - 1)] : &quot;-&quot;" line93="            }" line94="            return b" line95="        })" line96="" line97="        for (let b of hybrid) {" line98="            if (b !== &quot;-&quot;) {" line99="                music.playTone(noteFrequencies[b], music.beat(BeatFraction.Eighth))" line100="            } else {" line101="                pause(music.beat(BeatFraction.Eighth))" line102="            }" line103="        }" line104="    }" line105="" line106="    //% block=&quot;play seeded fixed song&quot;" line107="    export function playSeededSong(): void {" line108="        noteLog = []" line109="        randomizeInstrument()" line110="" line111="        const melodyNotes = [&quot;C4&quot;, &quot;E4&quot;, &quot;G4&quot;, &quot;A4&quot;, &quot;F4&quot;, &quot;E4&quot;, &quot;D4&quot;, &quot;C5&quot;]" line112="        const baseFreq = 110" line113="        const scale = currentKeyIsMajor ? majorScale : minorScale" line114="" line115="        for (let j = 0; j &lt; melodyNotes.length; j++) {" line116="            // Use seed to select the octave offset" line117="            const octaveOffset = (rngSeed + j) % 2" line118="            const noteName = melodyNotes[j]" line119="            const freq2 = noteFrequencies[noteName] * Math.pow(2, octaveOffset)" line120="            noteLog.push(freq2)" line121="" line122="            music.play(music.createSoundEffect(" line123="                currentWave," line124="                freq2," line125="                freq2," line126="                255," line127="                0," line128="                400," line129="                SoundExpressionEffect.None," line130="                InterpolationCurve.Linear" line131="            ), music.PlaybackMode.UntilDone)" line132="            pause(400)" line133="        }" line134="    }" line135="" line136="    //% block=&quot;play chill ambient sequence&quot;" line137="    export function playAmbientSequence(): void {" line138="        randomizeInstrument()" line139="        for (let k = 0; k &lt; 10; k++) {" line140="            const freq3 = getRandomNote()" line141="            music.play(music.createSoundEffect(" line142="                currentWave," line143="                freq3," line144="                freq3," line145="                180," line146="                0," line147="                300 + seededRandom(0, 200)," line148="                SoundExpressionEffect.None," line149="                InterpolationCurve.Curve" line150="            ), music.PlaybackMode.UntilDone)" line151="            pause(150 + seededRandom(0, 150))" line152="        }" line153="    }" line154="}" numlines="155"></mutation></block></statement></block></xml>